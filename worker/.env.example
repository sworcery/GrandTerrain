MOD_JAR_PATH=/app/data/grandterrain.jar
FABRIC_API_JAR_PATH=/app/data/fabric-api.jar
SERVER_JAR_PATH=/app/data/fabric-server-launch.jar
CHUNKY_JAR_PATH=/app/data/chunky.jar
SERVER_STARTUP_TIMEOUT=180
GENERATION_SETTLE_TIME=30
CORS_ORIGINS=*
MAX_CONCURRENT_JOBS=1
JOB_RETENTION_HOURS=24
# Pre-generation radius in blocks from spawn (2000 = a 4000x4000 area); 0 disables.
PREGEN_RADIUS=2000
# Hard cap on pre-generation time in seconds; partial pre-gen is still packaged.
PREGEN_TIMEOUT=21600
# Jars are auto-downloaded on first boot; override sources if needed:
# SERVER_JAR_URL=..., FABRIC_API_JAR_URL=..., CHUNKY_JAR_URL=..., MOD_JAR_URL=...
